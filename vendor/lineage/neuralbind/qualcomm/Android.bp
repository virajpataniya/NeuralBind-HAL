cc_binary {
    name: "android.hardware.neuralbind-service",
    relative_install_path: "hw",
    vendor: true,
    
    srcs: [
        "service.cpp",
        "NeuralBindImpl.cpp",
    ],
    
    // TELL THE COMPILER WHERE TO FIND THE HEADERS
    include_dirs: [
        "external/tensorflow",
        "external/flatbuffers/include",
    ],
    
    shared_libs: [
        "libbase",
        "libbinder_ndk",
        "liblog",
        "libutils",
        "android.hardware.neuralbind-V1-ndk",
        "libtflite", // <-- Using the OS's built-in, unstripped engine!
    ],
    
    vintf_fragments: ["neuralbind_manifest.xml"],
    init_rc: ["neuralbind-service.rc"],
    
    cflags: [
        "-Wall",
        "-Werror",
    ],
    
    cpp_std: "gnu++20",
}