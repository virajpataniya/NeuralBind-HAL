cc_binary {
    name: "android.hardware.neuralbind-service",
    relative_install_path: "hw",
    vendor: true,
    
    srcs: [
        "service.cpp",
        "NeuralBindImpl.cpp",
    ],
    
    include_dirs: [
        "vendor/lineage/neuralbind/qualcomm/llamacpp/include",
        "vendor/lineage/neuralbind/qualcomm/llamacpp/ggml/include",
    ],
    
    shared_libs: [
        "libbase",
        "libbinder_ndk",
        "liblog",
        "libutils",
        "android.hardware.neuralbind-V1-ndk",
        // DELETED libtflite!
    ],
    
    // ADD THE NEW ENGINE HERE:
    static_libs: [
        "libllamacpp_static",
        "libggml_c",
    ],
    
    vintf_fragments: ["neuralbind_manifest.xml"],
    init_rc: ["neuralbind-service.rc"],
    
    cflags: [
        "-Wall",
        "-Werror",
    ],
    
    cpp_std: "gnu++20",
}